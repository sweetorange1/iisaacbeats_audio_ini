         OptionWindowShort          = 0x00000000,
         OptionWindowMedium         = 0x00100000,
 
+        // Resampler quality selector (mapped to BQResampler::Quality)
+        OptionResamplerFastestTolerable = 0x00000000,
+        OptionResamplerBest             = 0x00010000,
